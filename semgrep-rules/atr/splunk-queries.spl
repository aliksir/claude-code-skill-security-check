    OR match(content, "(?i)(?:render|generate|produce|output)\\s+(?:a\\s+|an\\s+|the\\s+)?(?:markdown\\s+)?(?:image|link)\\s+(?:tag\\s+)?(?:where|with|containing|that\\s+includes)\\s+[\\s\\S]{0,80}(?:api[\\s_-]?key|access[\\s_-]?token|secret|password|credential|env(?:ironment)?[\\s_-]?(?:variable|var))")
)
