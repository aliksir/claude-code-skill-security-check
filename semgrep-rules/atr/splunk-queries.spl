``` ATR Rule: ATR-2026-00080 ```
``` Title: Encoding-Based Prompt Injection Evasion ```
``` Severity: high | Category: prompt-injection ```
``` Source: llm_io | Condition logic: any ```

index=ai_agent_logs sourcetype=agent_events
| where (
    match(user_input, "(?i)\\b(ignore|disregard|forget|override)\\b.{0,40}\\b(instruction|rule|system|prompt)\\b.{0,60}(base64|atob|btoa|\\\\x[0-9a-f]{2}|\\\\u[0-9a-f]{4})")
    OR match(user_input, "(?i)(eval|decode|atob|fromCharCode|String\\.fromCodePoint)\\s*\\(\\s*['\"]([A-Za-z0-9+/=]{20,}|\\\\x[0-9a-f]{2})")
    OR match(user_input, "(?i)(\\\\u0{0,2}[0-9a-f]{2,4}\\s*){5,}")
    OR match(user_input, "\\xE2\\x80\\x8F|\\xE2\\x80\\xAE|\\u200F|\\u202E|\\u2066|\\u2067|\\u2068|\\u2069")
    OR match(user_input, "(?i)xn--[a-z0-9]{4,}\\.\\s*.{0,30}\\b(ignore|new instructions|system prompt)")
)
