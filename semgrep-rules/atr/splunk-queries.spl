``` ATR Rule: ATR-2026-00021 ```
``` Title: Credential and Secret Exposure in Agent Output ```
``` Severity: critical | Category: context-exfiltration ```
``` Source: llm_io | Condition logic: any ```

index=ai_agent_logs sourcetype=agent_events
| where (
    match(agent_output, "sk-[a-zA-Z0-9]{20,}")
    OR match(agent_output, "AKIA[0-9A-Z]{16}")
    OR match(agent_output, "AIza[a-zA-Z0-9_-]{35}")
    OR match(agent_output, "(?:sk_live|pk_live|sk_test|rk_live)_[a-zA-Z0-9]{20,}")
    OR match(agent_output, "eyJ[a-zA-Z0-9_-]{10,}\\.eyJ[a-zA-Z0-9_-]{10,}\\.[a-zA-Z0-9_-]+")
    OR match(agent_output, "-----BEGIN (?:RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----")
    OR match(agent_output, "ghp_[a-zA-Z0-9]{36}")
    OR match(agent_output, "xox[bpors]-[a-zA-Z0-9\\-]{10,}")
    OR match(agent_output, "Bearer\\s+[a-zA-Z0-9\\-._~+/]{20,}=*")
    OR match(agent_output, "(?:mongodb(?:\\+srv)?|postgres(?:ql)?|mysql|redis|amqp)://[^\\s\"']{10,}")
    OR match(agent_output, "(?:DB_PASSWORD|DATABASE_URL|REDIS_URL|MONGO_URI|SECRET_KEY|JWT_SECRET|ENCRYPTION_KEY|PRIVATE_KEY|AUTH_TOKEN)\\s*[=:]\\s*[\"']?[^\\s\"']{8,}")
    OR match(agent_output, "(?:api[_-]?key|api[_-]?secret|access[_-]?token|auth[_-]?token|client[_-]?secret)\\s*[=:]\\s*[\"']?[a-zA-Z0-9_\\-]{16,}")
    OR match(agent_output, "(?:ANTHROPIC_API_KEY|OPENAI_API_KEY|GOOGLE_API_KEY|AZURE_API_KEY|COHERE_API_KEY|HF_TOKEN)\\s*[=:]\\s*[^\\s]{8,}")
    OR match(agent_output, "(?:ssh-rsa|ssh-ed25519|ecdsa-sha2-nistp256)\\s+[A-Za-z0-9+/]{40,}")
    OR match(agent_output, "(?:secret[\"'\\s]*[:=][\"'\\s]*[a-zA-Z0-9]{16,}|password[\"'\\s]*[:=][\"'\\s]*[^\\s\"']{8,})")
)
