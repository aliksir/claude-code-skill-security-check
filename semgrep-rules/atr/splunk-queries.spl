index=ai_agent_logs sourcetype=agent_events
| where (
    match(content, "(?i)(?:auth(?:entication)?|signature|token|hmac|nonce)\\s*[:=]\\s*(?:null|none|empty|missing|undefined|false|0|\"\")")
    OR match(content, "(?i)(?:forward(?:ed)?|relay(?:ed)?|proxy|pass(?:ed)?\\s+through)\\s+(?:from|by|via)\\s+[a-zA-Z0-9_-]+\\s+(?:without|no|missing)\\s+(?:verification|validation|auth|signature|check)")
    OR match(content, "(?i)(?:replay(?:ed|ing)?|re-?send(?:ing)?|duplicate)\\s+(?:message|request|command|instruction)\\s+(?:from|with|using)\\s+(?:timestamp|id|nonce)\\s*[:=]?\\s*[\"']?\\d{4}[-/]\\d{2}")
    OR match(content, "(?i)(?:channel|endpoint|destination|routing)\\s*[:=]\\s*[\"']?(?:debug|test|internal|admin|privileged|unmonitored|raw)[\"']?")
    OR match(content, "(?i)(?:broadcast|multicast|flood)\\s+(?:to\\s+)?(?:all|every|each)\\s+(?:agents?|workers?|nodes?|peers?)\\s*[:.]")
    OR match(content, "(?i)(?:inject(?:ed|ing)?|insert(?:ed|ing)?|append(?:ed|ing)?)\\s+(?:into|to)\\s+(?:message\\s+)?(?:queue|bus|stream|channel|pipeline)\\s+(?:directly|without|bypassing)")
    OR match(content, "(?i)(?:trust(?:ed)?|verify|accept)\\s+(?:all|any|every)\\s+(?:incoming|inbound|received)\\s+(?:messages?|commands?|requests?|instructions?)\\s+(?:from|without)")
    OR match(content, "(?i)(?:message_id|msg_id|request_id)\\s*[:=]\\s*[\"']?(?:forged|spoofed|fake|crafted|manipulated)[\"']?")
    OR match(content, "(?i)(?:man[_-]?in[_-]?(?:the)?[_-]?middle|intercept(?:ed|ing)?|eavesdrop(?:ping)?|sniff(?:ing)?)\\s+(?:on\\s+)?(?:agent|inter-agent|a2a)\\s+(?:communication|messages?|traffic)")
    OR match(content, "(?i)(?:unsigned|unauthenticated|unverified)\\s+(?:command|instruction|directive|action|message)\\s+(?:received|accepted|processed|executed)")
    OR match(content, "(?i)(?:source|sender|origin|from)\\s*[:=]\\s*[\"']?(?:unknown|unverified|anonymous|spoofed|forged|untrusted)[\"']?")
    OR match(content, "(?i)(?:delegation|handoff|transfer)\\s+(?:chain|path)\\s*[:=].*(?:>|->|=>).*(?:>|->|=>).*(?:>|->|=>)")
)
