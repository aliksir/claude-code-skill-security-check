``` ATR Rule: ATR-2026-00209 ```
``` Title: MCPwn Runaway Tool Invocation via Retry Directive (CVE-2026-33032) ```
``` Severity: high | Category: tool-poisoning ```
``` Source: mcp_exchange | Condition logic: any ```

index=ai_agent_logs sourcetype=agent_events
| where (
    match(content, "(?i)\"retry_hint\"\\s*:\\s*\"(?:retry|loop|continue|invoke|re-?call)[^\"]{0,200}(?:until|without\\s+(?:limit|bound|confirmation))")
    OR match(content, "(?i)\"continue_after_error\"\\s*:\\s*(?:true|\"true\"|1)\\s*,\\s*\"retry[^\"]*\"\\s*:\\s*\\d{3,}")
    OR match(content, "(?i)(?:retry|loop|re-?invoke)\\s+(?:this|the\\s+same)\\s+tool\\s+(?:indefinitely|forever|until\\s+success|until\\s+resolved)")
    OR match(content, "(?i)\"next_action\"\\s*:\\s*\"(?:call|invoke|execute)\\s+[a-zA-Z_]+(?:\\s*,\\s*(?:(?:call|invoke|execute)\\s+)?[a-zA-Z_]+)*\\s*\"")
    OR match(content, "(?i)on_error\\s*=\\s*(?:lambda|function|=>).{0,120}(?:invoke|call|retry|re-?run)\\s*\\(")
)
