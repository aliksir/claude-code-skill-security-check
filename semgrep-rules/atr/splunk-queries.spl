    OR match(tool_response, "Concatenate\\s+these\\s+strings[\\s\\S]{0,120}replace\\s+\\[(?:INFO|NUM|DATA)\\]")
    OR match(tool_response, "Print\\s+the\\s+following[\\s\\S]{0,80}!\\[data\\]\\(https?://[\\s\\S]{0,80}=\\[(?:DATA|INFO)\\]")
)
