    match(content, "(?i)(note|attention|message|instruction|directive|reminder|update|notice)\\s+(to|for)\\s+(the\\s+)?(AI|assistant|agent|model|system|chatbot|bot|LLM)\\s*[:\\-,.]\\s*.{0,30}(previous|prior|earlier|above|last|initial)\\s+.{0,30}(incorrect|wrong|flawed|erroneous|inaccurate|outdated|invalid|error)")
