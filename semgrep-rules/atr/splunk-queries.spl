index=ai_agent_logs sourcetype=agent_events
| where (
    match(user_input, "(?i)\\b(new|updated|revised|replacement|corrected|actual|real|true|proper|authentic|overriding|amended|modified|changed|current)\\s+(system\\s+)?(prompt|message|instructions?|directives?|guidelines?|configuration|persona|behavior|role\\s+definition)\\s*[:=\\-]")
    OR match(user_input, "(?i)<\\|?(im_start|im_end|system|endoftext|pad|sep|cls|eos|bos)\\|?>")
    OR match(user_input, "(?i)(<<\\s*SYS\\s*>>|<<\\s*/SYS\\s*>>|\\[INST\\]|\\[/INST\\]|<s>\\s*\\[INST\\]|<\\|begin_of_text\\|>|<\\|start_header_id\\|>\\s*system|<\\|end_header_id\\|>|<\\|eot_id\\|>)")
    OR match(user_input, "(?i)\\bsystem\\s*:\\s*(you\\s+are|your\\s+(role|purpose|task|job|function|objective|mission|goal)\\s+(is|shall\\s+be|will\\s+be)|from\\s+now|ignore|disregard|override|forget|the\\s+following|new\\s+instructions?|revised\\s+instructions?)")
    OR match(user_input, "(?i)\\b(replace|overwrite|redefine|reset|change|modify|update|set|reconfigure|reprogram|rewrite|reassign|swap|alter|transform|mutate)\\s+(your|the|current|existing|active|original|default)\\s+(system\\s+)(prompt|instructions?|persona|identity|role|behavior|guidelines?|directives?|personality|character|purpose|objective|mission)\\b")
    OR match(user_input, "(?i)\\{\\s*[\"']?(role|system_prompt|system_message|system_instruction|system_content|system|persona|identity|character)[\"']?\\s*:\\s*[\"']?")
    OR match(user_input, "(?i)(#{1,3})\\s*(system|instruction|configuration|override|admin|root|master)\\s*(prompt|message|section|override|directive|configuration)?\\s*\\1?")
    OR match(user_input, "(?i)(the\\s+)?(above|previous|original|old|prior|initial|default|existing|current|given)\\s+(system\\s+)?(prompt|instructions?|message|guidelines?|directives?|configuration|rules?)\\s+(is|are|was|were|has\\s+been|have\\s+been|should\\s+be)\\s+(deprecated|invalid|outdated|replaced|revoked|cancelled|superseded|overridden|void|nullified|expired|incorrect|wrong|fake|false|a\\s+test|not\\s+(real|valid|correct|applicable))")
    OR match(user_input, "(?i)(\\[|<|\\{\\{)\\s*(SYSTEM_OVERRIDE|ADMIN_OVERRIDE|ROOT_ACCESS|MASTER_PROMPT|PRIORITY_OVERRIDE|EMERGENCY_OVERRIDE|SECURITY_OVERRIDE|DEVELOPER_ACCESS|SUPER_USER|PRIVILEGED_MODE|MAINTENANCE_MODE|DEBUG_OVERRIDE|CONTROL_OVERRIDE|AUTH_BYPASS|ELEVATED_ACCESS)\\s*(\\]|>|\\}\\})")
    OR match(user_input, "(?i)<\\s*(system|system_prompt|system_message|system_instruction|instructions?|configuration|admin_directive|root_command|override|priority_instruction)\\s*>")
    OR match(user_input, "(?i)(the\\s+)?real\\s+(instructions?|prompt|guidelines?|directives?)\\s+(is|are)\\s+as\\s+follows|here\\s+(is|are)\\s+(your|the)\\s+(actual|real|true|correct|proper)\\s+(instructions?|prompt|guidelines?|directives?)|below\\s+(is|are)\\s+(your|the)\\s+updated\\s+(instructions?|prompt|guidelines?)")
    OR match(user_input, "(?i)(config|configuration|settings?|params|parameters)\\s*[=:]\\s*\\{[^}]{0,200}(role|system|instructions?|persona|behavior|safety|filter|restriction|guardrail)\\s*[=:]")
    OR match(user_input, "(?i)(---+|===+|\\*\\*\\*+|~~~+)\\s*(system|instruction|override|admin|configuration|new\\s+prompt)\\s*(---+|===+|\\*\\*\\*+|~~~+)")
    OR match(user_input, "(?i)\\[\\s*(system\\.prompt|system\\.config|agent\\.instructions|agent\\.persona|agent\\.role)\\s*\\]")
    OR match(user_input, "(新的|更新的|修改的|替换的|替換的|正确的|正確的|真正的|实际的|實際的|覆盖的|覆蓋的).{0,5}(系统|系統)?.{0,5}(提示词|提示詞|指令|指示|规则|規則|配置|设定|設定|人设|人設|角色定义|角色定義).{0,3}(：|:|=|-)")
    OR match(user_input, "(以上|上面|之前|原来的|原來的|旧的|舊的|默认的|默認的|现有的|現有的|当前的|當前的).{0,5}(系统|系統)?.{0,5}(提示词|提示詞|指令|指示|规则|規則|配置|设定|設定).{0,5}(已经|已經|是|已|都).{0,5}(过期|過期|无效|無效|作废|作廢|被替换|被替換|被覆盖|被覆蓋|不再适用|不再適用|错误|錯誤|假的)")
    OR match(user_input, "(替换|替換|覆盖|覆蓋|重写|重寫|修改|更改|更新|重新设定|重新設定|重新定义|重新定義|重新配置|重置).{0,5}(你的|当前|當前|现有|現有|原来|原來).{0,5}(系统|系統).{0,5}(提示词|提示詞|指令|指示|规则|規則|配置|人设|人設|身份|角色)")
    OR match(user_input, "(【|「|『|\\{\\{).{0,3}(系统|系統|SYSTEM|管理员|管理員|ADMIN|优先|優先|紧急|緊急|覆盖|覆蓋).{0,3}(】|」|』|\\}\\})")
    OR match(user_input, "(新しい|更新された|修正された|置き換えの|正しい|本当の|実際の|上書きの).{0,5}(システム)?.{0,5}(プロンプト|指示|命令|ルール|設定|ガイドライン|ペルソナ|役割定義).{0,3}(：|:|=|-)")
    OR match(user_input, "(上記の|前の|以前の|元の|旧い|デフォルトの|既存の|現在の).{0,5}(システム)?.{0,5}(プロンプト|指示|命令|ルール|設定|ガイドライン).{0,5}(は)?.{0,5}(期限切れ|無効|廃止|置き換え|上書き|適用外|間違い|偽物)")
    OR match(user_input, "(あなたの|現在の|既存の|元の).{0,5}(システム).{0,5}(プロンプト|指示|命令|ルール|設定|ペルソナ|アイデンティティ|役割).{0,5}(を)?.{0,5}(置き換え|上書き|書き換え|変更|更新|再設定|再定義|リセット)")
    OR match(user_input, "(【|「|『|\\{\\{).{0,3}(システム|SYSTEM|管理者|ADMIN|優先|緊急|オーバーライド).{0,3}(】|」|』|\\}\\})")
    OR match(user_input, "(새로운|업데이트된|수정된|대체|올바른|진짜|실제|덮어쓰기).{0,5}(시스템)?.{0,5}(프롬프트|지시|명령|규칙|설정|가이드라인|페르소나|역할 정의).{0,3}(：|:|=|-)")
