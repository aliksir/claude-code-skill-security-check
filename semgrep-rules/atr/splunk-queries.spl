    OR match(user_input, "(?i)(```\\s*(system|instruction|override|hidden)[\\s\\S]{0,200}```|\\*\\*\\*[\\s\\S]{0,10}(ignore|override|disregard)[\\s\\S]{0,200}\\*\\*\\*)")
    OR match(user_input, "(?i)(ignora|ignorar|olvida|olvidar|descarta|descartar|omite|omitir|anula|anular)\\s+(todas?\\s+)?(las?\\s+)?(instrucciones|reglas|directrices|restricciones|indicaciones|limitaciones)\\s+(previas|anteriores|originales|existentes|actuales)")
    OR match(user_input, "(?i)(ignoriere|vergiss|missachte|umgehe|verwirf)\\s+(alle[sn]?|die\\s+)?(vorherigen?|bisherigen?|aktuellen?|bestehenden?)?\\s*(Anweisungen|Regeln|Richtlinien|Anordnungen|Vorgaben|Instruktionen|Beschraenkungen|Aufgaben|Informationen|alles)")
    OR match(user_input, "(?i)(vergiss|ignoriere|vergessen\\s+Sie)\\s+(alles|das|dies)\\s*(was|davor|zuvor|vorher|bisher)?\\b")
    OR match(user_input, "(?i)neue\\s+(Aufgabe|Aufgaben|Anweisung|Anweisungen)\\s*(folgen|kommen|sind|:|,)")
    OR match(user_input, "(?i)(ignorieren\\s+Sie|vergessen\\s+Sie|beachten\\s+Sie\\s+nicht)\\s+(die\\s+)?(obigen?|vorherigen?|bisherigen?)?\\s*(Anweisungen|Regeln|Richtlinien|alles|Ausf[uü]hrungen|Informationen)")
    OR match(user_input, "(?i)(die\\s+)?(obigen?|vorherigen?)\\s+(Ausf[uü]hrungen|Anweisungen|Informationen|Texte?)\\s+(ignorier|vergess|missacht|[uü]bergeh)")
    OR match(user_input, "(?i)(alle[ns]?\\s+)?(vorangegangenen?|vorherigen?|bisherigen?)\\s+(Aufgaben|Informationen|Anweisungen)\\s+(aus\\s+dem\\s+Kopf|hinter\\s+sich|vergessen|fallen\\s+lassen|streichen)")
    OR match(user_input, "(?i)ACHTUNG\\s*[-:!]?\\s*(STOPP|STOP|HALT)\\s*[-:!]?")
    OR match(user_input, "(?i)(oubliez?|ignorez?|ne\\s+tenez\\s+pas\\s+compte)\\s+(de\\s+)?(toutes?\\s+)?(les\\s+)?(instructions?|regles|consignes|directives)\\s*(precedentes?|anterieures?|ci-dessus)?")
    OR match(user_input, "(تجاهل|انسَ|تخطَّ|ألغِ|أهمل|اترك|اسقط).{0,20}(التعليمات|الأوامر|القواعد|القيود|الإرشادات|التوجيهات).{0,10}(السابقة|الأصلية|الحالية|القديمة)")
    OR match(user_input, "(?i)(забудь|забудьте|игнорируй|игнорируйте|проигнорируй|отбрось|отбросьте)\\s+(все|всё|предыдущие|прежние)?\\s*(инструкции|правила|указания|команды|ограничения)")
    OR match(user_input, "(?i)(zaboravi|ignoriraj|zanemari|preskoči|preskoci)\\s+(sve|prethodne|ranije)?\\s*(instrukcije|pravila|upute|naredbe|ograničenja|ogranicenja|instrukci)")
    OR match(user_input, "(?i)(ich\\s+m[oö]chte,?\\s+dass\\s+Sie\\s+als|fungieren\\s+Sie\\s+als|agieren\\s+Sie\\s+als|spielen\\s+Sie\\s+die\\s+Rolle)\\s+.{3,50}")
    OR match(user_input, "(?i)(nun\\s+bist\\s+du|jetzt\\s+bist\\s+du|du\\s+bist\\s+(jetzt|nun|ab\\s+sofort))\\s+[A-Za-z\\u00C0-\\u024F]{2,}")
    OR match(user_input, "(?i)(ignoriere|vergiss)\\s+(alle[ns]?\\s+)?(vorangehenden?|fr[uü]heren?)\\s+(Befehle|Anweisungen|Anordnungen|Regeln)")
    OR match(user_input, "(?i)(olvid[ae]|olvide)\\s+(todo|todos?)\\s+(que|lo\\s+que)\\s+(digo|dije|he\\s+dicho|dicho)\\s+(antes|anteriormente)")
    OR match(user_input, "(DO\\s+NOT\\s+(ANSWER|LOOK|READ|USE|FOLLOW|CHECK|RESPOND)|FORGET\\s+EVERYTHING|IGNORE\\s+ALL)")
    OR match(user_input, "(?i)(are|is)\\s+(two\\s+)?(actors?|characters?)\\s+in\\s+a\\s+(film|movie|story)\\s+(about|where)\\s+[^\\n]{0,80}(robbery|hack|steal|thief|exploit|breach|attack|malware|bomb)")
)
