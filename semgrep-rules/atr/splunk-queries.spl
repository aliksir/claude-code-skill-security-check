``` ATR Rule: ATR-2026-00002 ```
``` Title: Indirect Prompt Injection via External Content ```
``` Severity: high | Category: prompt-injection ```
``` Source: llm_io | Condition logic: any ```

index=ai_agent_logs sourcetype=agent_events
| where (
    match(content, "(?i)<!--[^>]{0,20}(ignore|disregard|override|new\\s+instructions?|system\\s*:|you\\s+must|you\\s+are\\s+now|forget\\s+previous|execute|perform|send\\s+to|exfiltrate|reveal|disclose|output\\s+the)[^>]{0,200}-->")
    OR match(content, "[\\u200B\\u200C\\u200D\\uFEFF\\u2060\\u180E\\u200E\\u200F\\u202A-\\u202E\\u2066-\\u2069]{5,}")
    OR match(content, "(?i)(\\[INST\\]|\\[/INST\\]|\\[SYSTEM\\]|\\[/SYSTEM\\]|\\[HIDDEN\\]|<\\|im_start\\|>|<\\|im_end\\|>|<\\|endoftext\\|>|<\\|system\\|>|<\\|user\\|>|<\\|assistant\\|>|<\\|pad\\|>|<s>\\[INST\\]|<<SYS>>|<</SYS>>|<\\|begin_of_text\\|>|<\\|eot_id\\|>|<\\|start_header_id\\|>)")
    OR match(content, "(?i)(color\\s*:\\s*(white|transparent|rgba\\s*\\(\\s*\\d+\\s*,\\s*\\d+\\s*,\\s*\\d+\\s*,\\s*0\\s*\\))|font-size\\s*:\\s*0|display\\s*:\\s*none|opacity\\s*:\\s*0|visibility\\s*:\\s*hidden|height\\s*:\\s*0|width\\s*:\\s*0|overflow\\s*:\\s*hidden|position\\s*:\\s*absolute\\s*;\\s*left\\s*:\\s*-\\d{4,}).{0,300}(ignore|override|instruction|system\\s*prompt|disregard|execute|you\\s+must|you\\s+are|forget|reveal|disclose)")
    OR match(content, "(?i)\\b(AI|assistant|agent|model|chatbot|LLM|GPT|Claude)\\s*[,:;]?\\s*(please\\s+)?(you\\s+must|you\\s+should|you\\s+need\\s+to|you\\s+are\\s+instructed\\s+to|immediately|now\\s+)\\s*(ignore|disregard|override|execute|run|perform|send|forward|reveal|disclose|output|respond\\s+with|comply|obey)")
    OR match(content, "(?i)(base64[_\\-]?decode|atob|Buffer\\.from|b64decode|base64\\s+(-d|--decode))\\s*\\(?\\s*['\"]?[A-Za-z0-9+/]{16,}={0,2}")
    OR match(content, "(?i)<\\s*(div|span|p|section|article|aside|details|summary)\\s+[^>]*(hidden|aria-hidden\\s*=\\s*[\"']true[\"']|style\\s*=\\s*[\"'][^\"']*(?:display\\s*:\\s*none|visibility\\s*:\\s*hidden|opacity\\s*:\\s*0))[^>]*>[^<]{0,500}(instruction|prompt|ignore|override|disregard|execute|you\\s+must|you\\s+are|system|directive|comply)")
    OR match(content, "(?i)data\\s*:\\s*(text/html|text/plain|text/javascript|application/javascript|application/x-javascript)\\s*[;,]\\s*(base64\\s*,)?\\s*[A-Za-z0-9+/=%]+")
    OR match(content, "(?i)(\\!?\\[([^\\]]{0,100})\\]\\s*\\(\\s*(javascript|data|vbscript)\\s*:|\\!?\\[([^\\]]{0,100}(ignore|override|system|instruction|execute|you\\s+must)[^\\]]{0,100})\\])")
    OR match(content, "(?i)(background(-color)?\\s*:\\s*(#[fF]{3,6}|white|rgb\\s*\\(\\s*255))[^}]{0,100}(color\\s*:\\s*(#[fF]{3,6}|white|rgb\\s*\\(\\s*255))")
    OR match(content, "(?i)<\\s*(iframe|object|embed|frame)\\s+[^>]*(width\\s*=\\s*[\"']?0|height\\s*=\\s*[\"']?0|hidden|style\\s*=\\s*[\"'][^\"']*display\\s*:\\s*none)[^>]*>")
    OR match(content, "[\\u202A\\u202B\\u202C\\u202D\\u202E\\u2066\\u2067\\u2068\\u2069].{1,100}(ignore|override|system|instruction|execute|reveal)")
    OR match(content, "(&#105;|&#x69;)(&#103;|&#x67;)(&#110;|&#x6[eE];)(&#111;|&#x6[fF];)(&#114;|&#x72;)(&#101;|&#x65;)")
)
